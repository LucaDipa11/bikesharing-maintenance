          "response": []
        },
        {
          "name": "PUT - Aggiorna stato ticket",
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/tickets/1/status?status=IN_PROGRESS",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["tickets", "1", "status"],
              "query": [
                {"key": "status", "value": "IN_PROGRESS", "description": "Può essere: OPEN, ASSIGNED, IN_PROGRESS, COMPLETED"}
              ]
            },
            "description": "Aggiorna lo stato di un ticket. Stati: OPEN, ASSIGNED, IN_PROGRESS, COMPLETED"
          },
          "response": []
        },
