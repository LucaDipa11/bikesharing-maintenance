      "item": [
        {
          "name": "GET - Tutte le biciclette",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/bikes",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
